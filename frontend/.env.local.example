# Where the analyze API lives.
#
# In dev, point at your local Express server:
#   NEXT_PUBLIC_API_URL=http://localhost:4000/analyze
#
# When deploying to Vercel with the backend as serverless functions:
#   NEXT_PUBLIC_API_URL=https://<backend-project>.vercel.app/api/analyze
NEXT_PUBLIC_API_URL=http://localhost:4000/analyze
