# Gemini API key — required for the AI analysis layer.
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model (defaults to gemini-2.0-flash for speed)
GEMINI_MODEL=gemini-2.0-flash

# Express port (only used in standalone mode, not on Vercel serverless)
PORT=4000

# Comma-separated list of allowed CORS origins. Leave * for development.
CORS_ORIGIN=*
